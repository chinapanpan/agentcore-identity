            "content": [
              {
                "type": "text",
                "text": "{\"price_ratio\":2.0,\"impermanent_loss_pct\":-5.7191,\"note\":\"相对持有的无常损失(负数=损失)\"}"
              }
            ]
          }
        }
      },
      "place_order": {
        "http": 200,
        "payload": {
          "jsonrpc": "2.0",
          "id": 1,
